{
  "name": "worldforge",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first desktop writing workstation for a single author",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "package": "node scripts/package-foundation.mjs",
    "release:check": "node scripts/release-tool.mjs check",
    "release:gate": "node scripts/release-tool.mjs gate",
    "release:checksums": "node scripts/release-tool.mjs checksums",
    "lint": "eslint .",
    "format": "prettier --write \"scripts/**/*.mjs\" \"apps/**/*.{ts,json,mjs,html,css}\" \"packages/**/*.{ts,json}\" \"tests/**/*.ts\" \".github/**/*.{yaml,yml}\" \"*.{json,yaml,yml,mjs,ts}\"",
    "format:check": "prettier --check \"scripts/**/*.mjs\" \"apps/**/*.{ts,json,mjs,html,css}\" \"packages/**/*.{ts,json}\" \"tests/**/*.ts\" \".github/**/*.{yaml,yml}\" \"*.{json,yaml,yml,mjs,ts}\"",
    "typecheck": "pnpm --filter @worldforge/contracts build && pnpm -r --if-present typecheck",
    "test": "vitest run && node apps/desktop/main/run-ci-e2e.mjs",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "pnpm build && node apps/desktop/main/run-e2e.mjs",
    "test:security": "vitest run tests/security",
    "test:migration": "vitest run tests/migration",
    "test:perf": "node scripts/not-ready.mjs M0-06 test:perf",
    "test:eval": "node scripts/not-ready.mjs M0-07 test:eval",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:workspaces": "node scripts/check-workspaces.mjs",
    "task:status": "node scripts/taskctl.mjs status",
    "task:validate": "node scripts/taskctl.mjs validate",
    "task:preflight": "node scripts/taskctl.mjs preflight",
    "task:verify": "node scripts/taskctl.mjs verify",
    "task:sync": "node scripts/taskctl.mjs sync",
    "task:activate": "node scripts/taskctl.mjs activate",
    "task:close": "node scripts/taskctl.mjs close"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@worldforge/contracts": "workspace:*",
    "electron": "43.1.1",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
